FROM docker.io/library/python:3.12-slim AS python-deps

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

FROM docker.io/library/node:22-slim

# Copy Python runtime and installed packages from the Python stage
COPY --from=python-deps /usr/local /usr/local

RUN npm install -g supergateway

WORKDIR /app
COPY server.py catalog-data.json ./

EXPOSE 8083

USER node

CMD ["supergateway", \
     "--stdio", "python3 /app/server.py", \
     "--port", "8083", \
     "--outputTransport", "streamableHttp", \
     "--statefulMode"]
